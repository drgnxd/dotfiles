#!/usr/bin/env bash
set -euo pipefail

config="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hyprland.conf"

grep -E '^\s*bind\s*=' "$config" \
    | sed 's/^\s*bind\s*=\s*//' \
    | awk -F',' '{
        mods = $1
        key = $2
        gsub(/^ +| +$/, "", mods)
        gsub(/^ +| +$/, "", key)

        desc = ""
        for (i = 3; i <= NF; i++) {
            if (desc != "") desc = desc ","
            desc = desc $i
        }
        gsub(/^ +| +$/, "", desc)
        printf "%-20s  %s\n", mods " + " key, desc
    }' \
    | sort \
    | wofi --dmenu --prompt "Keybindings" --width 800 --height 600
