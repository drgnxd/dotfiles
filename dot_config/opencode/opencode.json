{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-terra",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "build",
  "enabled_providers": [
    "openai",
    "github-copilot",
    "opencode"
  ],
  "provider": {
    "openai": {
      "whitelist": [
        "gpt-5.4-mini",
        "gpt-5.5",
        "gpt-5.6-terra",
        "gpt-5.6-sol"
      ],
      "options": {
        "headerTimeout": 60000
      }
    },
    "opencode": {
      "whitelist": [
        "deepseek-v4-flash-free"
      ]
    }
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.6-terra",
      "variant": "medium"
    },
    "plan": {
      "model": "openai/gpt-5.6-sol",
      "variant": "medium"
    },
    "general": {
      "model": "openai/gpt-5.6-terra",
      "variant": "medium"
    },
    "explore": {
      "model": "opencode/deepseek-v4-flash-free",
      "steps": 12
    },
    "scout": {
      "model": "openai/gpt-5.4-mini",
      "variant": "low",
      "steps": 12
    },
    "compaction": {
      "model": "openai/gpt-5.6-terra",
      "variant": "low"
    },
    "title": {
      "model": "openai/gpt-5.4-mini",
      "variant": "low"
    },
    "summary": {
      "model": "openai/gpt-5.4-mini",
      "variant": "low"
    },
    "review-deep": {
      "description": "Reviews complex or high-risk changes without editing; use for correctness, security, architecture, regressions, and missing tests.",
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "variant": "high",
      "steps": 20,
      "permission": {
        "edit": "deny"
      },
      "prompt": "Review without editing. Report material findings first, ordered by severity, with concrete file and line references. Focus on correctness, security, behavioral regressions, architecture, edge cases, and missing tests. State residual risks when no findings are discovered."
    }
  },
  "tool_output": {
    "max_lines": 1000,
    "max_bytes": 32768
  },
  "plugin": [
    "@mohak34/opencode-notifier@0.2.8"
  ]
}
